{
  "name": "signal-md",
  "version": "2.0.0",
  "description": "Signal MD - Medical Evidence Intelligence Platform",
  "main": "server.js",
  "engines": {
    "node": ">=22.13.0"
  },
  "volta": {
    "node": "22.14.0"
  },
  "scripts": {
    "start": "node server.js",
    "server": "node server.js",
    "proxy": "node server.js",
    "start:prod": "cross-env NODE_ENV=production node server.js",
    "start:e2e-server": "node scripts/start-e2e-server.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server.js",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "build:full": "npm run build",
    "build:prod": "tsc && vite build --mode production",
    "preview": "vite preview",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop medsearch-web medsearch-worker",
    "pm2:restart": "pm2 restart medsearch-web medsearch-worker",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "worker": "node server/worker.js",
    "test": "jest",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:all": "playwright test",
    "test:e2e:chrome": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install",
    "test:e2e:install-deps": "playwright install --with-deps",
    "test:e2e:report": "playwright show-report",
    "test:watch": "jest --watch",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "secrets:generate": "node scripts/generate-secrets.mjs",
    "verify:production-env": "node scripts/verify-production-env.mjs",
    "verify:infra": "node scripts/acceptance/infra-acceptance.js",
    "beta:safety": "node scripts/verify-beta-safety.mjs",
    "audit:auth-routes": "node scripts/audit-auth-routes.mjs",
    "audit:mega-files": "node scripts/audit-mega-files.mjs",
    "audit:flagship-topics": "node scripts/audit-flagship-program.mjs",
    "audit:flagship-readiness": "node server/scripts/auditFlagshipReadiness.js",
    "enrich:flagship-knowledge": "node server/scripts/enrichFlagshipKnowledge.js",
    "sync:flagship-sources": "node server/scripts/syncSourceArticles.js",
    "backfill:pdf-flagship": "node server/scripts/backfillPdfBouquet.js",
    "backfill:pdf-flagship:high": "node server/scripts/backfillPdfBouquet.js --priority=high --force-retry",
    "compose:hetzner:config": "docker compose -f docker-compose.hetzner.yml config",
    "verify:db-contract": "node tools/check-db-guards.js",
    "verify:sql-dialect": "node tools/check-sql-dialect.js",
    "verify:legacy-freeze": "node tools/check-legacy-freeze.js",
    "verify:legacy-removal-ready": "node tools/check-legacy-removal-ready.js",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json",
    "typecheck:all": "npm run typecheck && npm run typecheck:server",
    "db:reset": "node -e \"require('fs').existsSync('./database/app.db') && require('fs').unlinkSync('./database/app.db'); console.log('Database reset.')\"",
    "db:migrate": "node scripts/sqlite-migrate.mjs",
    "db:migrate:postgres": "cross-env USE_POSTGRES_MAIN=true node -e \"const db=require('./database');db.connect().then(()=>db.runMigrations()).then(r=>console.log(r)).finally(()=>db.close())\"",
    "db:rollback": "node scripts/db-rollback.mjs",
    "db:schema:check": "node scripts/check-schema-consistency.mjs",
    "db:schema:regen": "node scripts/regenerate-schemas.mjs",
    "db:migrate:builtin": "node scripts/sqlite-migrate.mjs",
    "db:migrate:kysely": "node -e \"const db = require('./database'); db.connect().then(() => db.runMigrations()).finally(() => db.close())\"",
    "db:backfill-canonical": "node server/scripts/backfillCanonicalTopics.js",
    "db:merge-topic-dupes": "node server/scripts/mergeDuplicateTopicKnowledge.js",
    "db:merge-flagship-clusters": "node server/scripts/mergeFlagshipCurriculumClusters.js",
    "backfill:flagship-knowledge": "node server/scripts/backfillFlagshipTopicKnowledge.js",
    "seed:ards": "node server/scripts/seedFlagshipArds.js",
    "qa:ards": "node server/scripts/qaArdsLive.js",
    "health": "curl http://localhost:3002/health",
    "test:e2e:real-auth": "playwright test --project=chromium-auth tests/e2e/real-auth-flows.spec.js",
    "test:e2e:real-llm": "playwright test --project=chromium-auth --grep \"@real-llm\" tests/e2e/real-auth-flows.spec.js",
    "eval:agent-quality": "node scripts/eval-agent-quality.js",
    "eval:agent-quality:report": "node scripts/eval-agent-quality.js --format=markdown",
    "eval:agent-quality:strict": "node scripts/eval-agent-quality.js --strict",
    "eval:search-quality": "node scripts/eval-search-quality.js",
    "eval:search-quality:gold": "node scripts/eval-search-quality.js --base http://localhost:3002 --gold tests/fixtures/search-quality-gold.json",
    "eval:search-quality:report": "node scripts/eval-search-quality.js --base http://localhost:3002",
    "eval:search-quality:suggest-aliases": "node scripts/suggest-landmark-aliases.js",
    "test:search-quality-gate": "npx jest --testPathPatterns=p3SearchQualityScale --no-coverage",
    "eval:offline-policy": "node scripts/eval-offline-policy.js",
    "eval:offline-policy:strict": "node scripts/eval-offline-policy.js --strict",
    "test:offline-policy": "npx jest --testPathPatterns=p4OfflinePolicyEval|policyReplayEvaluator --no-coverage",
    "check:service-boundaries": "node tools/check-service-boundaries.js",
    "test:platform-hardening": "npx jest --testPathPatterns=p5PlatformHardening|productionObservabilityService|eventBus|userInteractionService|appErrors|recommendationService --no-coverage",
    "eval:learning-quality": "node scripts/eval-learning-quality.js",
    "eval:quality-metrics": "node scripts/eval-quality-metrics.js",
    "eval:search-personalization": "node scripts/eval-search-personalization.js",
    "test:load:smoke": "k6 run tests/load/search-load.js -e TEST_TYPE=smoke",
    "test:load:normal": "k6 run tests/load/search-load.js -e TEST_TYPE=normal",
    "test:load": "k6 run tests/load/search-load.js -e TEST_TYPE=standard",
    "test:load:peak": "k6 run tests/load/search-load.js -e TEST_TYPE=peak",
    "test:load:stress": "k6 run tests/load/search-load.js -e TEST_TYPE=stress",
    "test:load:spike": "k6 run tests/load/search-load.js -e TEST_TYPE=spike",
    "test:load:soak": "k6 run tests/load/search-load.js -e TEST_TYPE=soak",
    "test:load:auth": "k6 run tests/load/authenticated-load.js",
    "test:load:rate-limit": "k6 run tests/load/rate-limit-audit.js",
    "test:load:report": "node tests/load/generate-report.js",
    "test:e2e:ci": "playwright test tests/e2e/research-flow.spec.js tests/e2e/learning-pipeline.spec.js --project=chromium --workers=1",
    "docs:openapi:generate": "node server/docs/openapiGenerator.js",
    "docs:openapi:validate": "node server/docs/validateOpenApi.js",
    "docs:openapi:serve": "node -e \"console.log('Swagger UI available at /api/docs when server is running')\""
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@sentry/node": "^10.58.0",
    "@sentry/react": "^10.58.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "bullmq": "^5.78.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "d3": "^7.9.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "express-slow-down": "^3.1.0",
    "fast-xml-parser": "^5.8.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "kysely": "^0.28.16",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^22.1.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sentry/vite-plugin": "^5.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.4.1",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.38",
    "prettier": "^3.1.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.4",
    "ts-jest": "^29.4.11",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.16",
    "vite-bundle-visualizer": "^1.2.1"
  },
  "keywords": [
    "medical",
    "research",
    "pubmed",
    "ai",
    "mistral",
    "semantic-scholar",
    "systematic-review"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "overridesNotes": {
    "ws": "Pinned to 8.21.0: patched DoS CVE-2024-37890 lineage; socket.io/engine.io and jsdom pull older ranges. Re-check with `npm ls ws` before removing.",
    "ts-jest": "29.4.x is the latest line and officially supports Jest 30 (peer range ^29 || ^30). No ts-jest 30 exists - do not 'fix' the apparent major-version skew."
  },
  "overrides": {
    "ws": "8.21.0"
  }
}
