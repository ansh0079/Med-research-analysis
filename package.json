{
  "name": "medical-research-analysis",
  "version": "2.0.0",
  "description": "Medical Research Intelligence Platform - Multi-source search with AI analysis",
  "main": "server.js",
  "engines": {
    "node": ">=22.13.0"
  },
  "volta": {
    "node": "22.14.0"
  },
  "scripts": {
    "start": "node server.js",
    "server": "node server.js",
    "proxy": "node server.js",
    "start:prod": "cross-env NODE_ENV=production node server.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server.js",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "build:full": "npm run build",
    "build:prod": "tsc && vite build --mode production",
    "preview": "vite preview",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop medsearch-web medsearch-worker",
    "pm2:restart": "pm2 restart medsearch-web medsearch-worker",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "worker": "node server/worker.js",
    "test": "jest",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:all": "playwright test",
    "test:e2e:chrome": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install",
    "test:e2e:install-deps": "playwright install --with-deps",
    "test:e2e:report": "playwright show-report",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "verify:db-contract": "node tools/check-db-guards.js",
    "verify:legacy-freeze": "node tools/check-legacy-freeze.js",
    "verify:legacy-removal-ready": "node tools/check-legacy-removal-ready.js",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json",
    "typecheck:all": "npm run typecheck && npm run typecheck:server",
    "db:reset": "node -e \"require('fs').existsSync('./database/app.db') && require('fs').unlinkSync('./database/app.db'); console.log('Database reset.')\"",
    "db:migrate": "node scripts/sqlite-migrate.mjs",
    "db:migrate:postgres": "cross-env USE_POSTGRES_MAIN=true node -e \"const db=require('./database');db.connect().then(()=>db.runMigrations()).then(r=>console.log(r)).finally(()=>db.close())\"",
    "db:schema:check": "node scripts/check-schema-consistency.mjs",
    "db:schema:regen": "node scripts/regenerate-schemas.mjs",
    "db:migrate:builtin": "node scripts/sqlite-migrate.mjs",
    "db:migrate:kysely": "node -e \"const db = require('./database'); db.connect().then(() => db.runMigrations()).finally(() => db.close())\"",
    "db:backfill-canonical": "node server/scripts/backfillCanonicalTopics.js",
    "db:merge-topic-dupes": "node server/scripts/mergeDuplicateTopicKnowledge.js",
    "seed:ards": "node server/scripts/seedFlagshipArds.js",
    "qa:ards": "node server/scripts/qaArdsLive.js",
    "health": "curl http://localhost:3002/health",
    "test:e2e:real-auth": "playwright test --project=chromium-auth tests/e2e/real-auth-flows.spec.js",
    "test:e2e:real-llm": "playwright test --project=chromium-auth --grep \"@real-llm\" tests/e2e/real-auth-flows.spec.js",
    "eval:agent-quality": "node scripts/eval-agent-quality.js",
    "eval:agent-quality:report": "node scripts/eval-agent-quality.js --format=markdown"
  },
  "dependencies": {
    "@sentry/node": "^8.55.2",
    "@sentry/react": "^8.55.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "bullmq": "^5.78.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "d3": "^7.9.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "kysely": "^0.28.16",
    "logrocket": "^12.1.0",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "stripe": "^22.1.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "esbuild": "^0.24.2",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.4.1",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.38",
    "prettier": "^3.1.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.4",
    "ts-jest": "^29.4.9",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-bundle-visualizer": "^1.2.1"
  },
  "keywords": [
    "medical",
    "research",
    "pubmed",
    "ai",
    "mistral",
    "semantic-scholar",
    "systematic-review"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  }
}
