# Load Testing Configuration
# Copy this file to .env and customize for your environment

# Base URL for the API under test
BASE_URL=http://localhost:3002

# Test environment name (local, staging, production)
ENVIRONMENT=local

# Default test type when not specified
# Options: smoke, normal, standard, peak, stress, spike, soak
TEST_TYPE=standard

# Output directory for test results
OUTPUT_DIR=./tests/load/results

# Enable debug logging (true/false)
DEBUG=false

# ============================================
# Advanced Configuration
# ============================================

# Request timeout in milliseconds
REQUEST_TIMEOUT=30000

# Maximum redirects to follow
MAX_REDIRECTS=10

# InfluxDB configuration for external metrics storage
# INFLUXDB_URL=http://localhost:8086
# INFLUXDB_DB=k6

# Cloud provider credentials for distributed testing
# K6_CLOUD_TOKEN=your_token_here
# K6_CLOUD_PROJECT_ID=your_project_id

# Custom thresholds (in milliseconds)
THRESHOLD_P95=500
THRESHOLD_P99=1000
THRESHOLD_ERROR_RATE=0.01
