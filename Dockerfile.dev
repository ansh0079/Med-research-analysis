# ==========================================
# Development Dockerfile
# Hot-reload friendly with volume mounts
# Usage: docker compose -f docker-compose.dev.yml up
# ==========================================

FROM node:22-alpine

WORKDIR /app

# Install git (used by Vite dependency optimization)
RUN apk add --no-cache git

COPY package*.json ./
RUN npm ci

COPY . .

EXPOSE 5173 3002

CMD ["npm", "run", "dev"]
