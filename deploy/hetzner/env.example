# Hetzner VPS production .env
# Copy to repo root on the server: cp deploy/hetzner/env.example .env

# --- Domain & TLS (required) ---
# Production: SignalMD — https://signalmd.co
DOMAIN=signalmd.co
ACME_EMAIL=you@signalmd.co

# --- Process role & URLs (required) ---
# Use APP_ROLE=worker and WORKER_HEALTH_PORT=3003 in the worker process.
APP_ROLE=web
APP_URL=https://signalmd.co
CORS_ORIGINS=https://signalmd.co

# --- Database (required) ---
POSTGRES_PASSWORD=change-me-strong-password
USE_POSTGRES_MAIN=true
PG_VECTOR_URL=postgresql://medsearch:replace-me@postgres:5432/medsearch

# --- Auth secrets (required) — run: npm run secrets:generate
JWT_SECRET=
SESSION_SECRET=
ADMIN_TOKEN=

# --- LLM & search APIs (at least GEMINI recommended) ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
NCBI_API_KEY=
NCBI_EMAIL=you@yourdomain.com
SEMANTIC_SCHOLAR_KEY=
HUGGINGFACE_TOKEN=

# --- Email (required for production verification, reset, and digests) ---
REQUIRE_SMTP=true
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Signal MD <hello@signalmd.co>

# --- Billing (required for commercial readiness) ---
REQUIRE_STRIPE=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_RESEARCHER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
PAYWALL_ENABLED=true

# --- Search (required for commercial readiness) ---
REQUIRE_VECTOR_SEARCH=true

# --- Beta programme (anonymous session access, no sign-in for AI/quiz) ---
# true while the invite-gated beta is running; set to false at commercial launch.
BETA_MODE=true

# --- Logging ---
LOG_LEVEL=info

# --- Error tracking ---
SENTRY_DSN=
