# Hetzner VPS production .env
# Copy to repo root on the server: cp deploy/hetzner/env.example .env
#
# Canonical production checklist: .env.production.example
# docker-compose.hetzner.yml injects DATABASE_URL, REDIS_URL, APP_URL, and CORS from DOMAIN.
# Pre-flight: NODE_ENV=production npm run verify:production-env

# --- Domain & TLS (required) ---
DOMAIN=signalmd.co
ACME_EMAIL=you@signalmd.co

# --- Database (required) ---
POSTGRES_PASSWORD=change-me-strong-password

# --- Redis (required) — used by docker-compose for REDIS_URL ---
REDIS_PASSWORD=change-me-strong-redis-password

# --- Auth secrets (required) — run: npm run secrets:generate ---
JWT_SECRET=
SESSION_SECRET=
ADMIN_TOKEN=

# --- Runtime posture (compose overrides most URLs from DOMAIN) ---
# Keep BETA_MODE=false for commercial launch; true only for anonymous beta cohorts.
BETA_MODE=false
PAYWALL_ENABLED=false
PAYWALL_ALLOW_IN_DEV=false
AUTO_SEED_ON_SEARCH=false
LOG_LEVEL=info

# --- LLM & search APIs (at least one LLM key required) ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
NCBI_API_KEY=
NCBI_EMAIL=you@yourdomain.com
SEMANTIC_SCHOLAR_KEY=
HUGGINGFACE_TOKEN=
EMBEDDING_PROVIDER=hf
OPENAI_API_KEY=

# --- Email (required before REQUIRE_SMTP=true in compose) ---
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Signal MD <hello@signalmd.co>
EMAIL_SUPPRESSION_LIST=

# --- Billing (required before PAYWALL_ENABLED=true) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_RESEARCHER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

# --- Error tracking (required for production verify) ---
SENTRY_DSN=
SENTRY_RELEASE=2.0.0
SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_DSN=
VITE_SENTRY_ORG=signal-md
VITE_SENTRY_PROJECT=signal-md-frontend

# --- Agent / learning flags ---
AGENT_LLM_INTENT_CLASSIFIER=false
AGENT_TURN_MEMORY_ENABLED=true

# --- Optional tracing ---
OTEL_ENABLED=false
OTEL_SERVICE_NAME=signal-md
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
