# Medical Research Intelligence Platform - Environment Configuration

# =============================================================================
# API KEYS - External Services
# =============================================================================

# PubMed/NCBI API
# Get your API key at: https://www.ncbi.nlm.nih.gov/account/
# Canonical key used by the server:
NCBI_API_KEY=your_ncbi_api_key
# Backward-compatible alias (optional):
PUBMED_API_KEY=your_ncbi_api_key

# Semantic Scholar API
# Get your API key at: https://www.semanticscholar.org/product/api
# Canonical key used by the server:
SEMANTIC_SCHOLAR_KEY=your_semantic_scholar_api_key
# Backward-compatible alias (optional):
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key

# Gemini AI API (preferred provider for analysis/synthesis)
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Mistral AI API (fallback provider for analysis)
# Get your API key at: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key

# Anthropic API (used for guideline-anchored MCQ generation)
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================

# Sentry - Error Tracking (Free: 5k errors/month)
# Sign up at: https://sentry.io/signup/
# Backend (Node/Express) Sentry DSN
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_AI_TRACES_SAMPLE_RATE=0.2
# Frontend (Vite) Sentry DSN
VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@xxxxxxx.ingest.sentry.io/xxxxxxx
VITE_SENTRY_ORG=your-organization
VITE_SENTRY_PROJECT=medical-research-app
VITE_SENTRY_ENV=production

# LogRocket - Session Replay (Free: 1k sessions/month)
# Sign up at: https://logrocket.com/
VITE_LOGROCKET_APP_ID=your-org/your-app

# Analytics Provider: ga4 | plausible | mixpanel | none
VITE_ANALYTICS_PROVIDER=ga4
VITE_ANALYTICS_TRACKING_ID=G-XXXXXXXXXX
VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_DEBUG=false
VITE_ANALYTICS_SAMPLE_RATE=1.0

# UptimeRobot - Uptime Monitoring (Free: 50 monitors)
UPTIMEROBOT_API_KEY=your_uptimerobot_api_key

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Server Configuration (server.js uses NODE_PORT || PORT || 3002; Vite dev proxy reads the same from .env)
PORT=3002
NODE_ENV=production

# Main app database: SQLite path by default, or PostgreSQL URL if USE_POSTGRES_MAIN=true
DATABASE_PATH=./database/app.db
DATABASE_URL=./data/database.sqlite
# Set true only if migrating the full app to PostgreSQL (sessions, users, etc.)
USE_POSTGRES_MAIN=false
# Optional: dedicated pgvector database for article embeddings (recommended with Docker)
# Example: postgresql://medsearch:medsearch@localhost:5432/medsearch
PG_VECTOR_URL=
# Backward-compatible alias
VECTOR_DATABASE_URL=
# true if Postgres requires SSL (e.g. cloud)
PGSSL=false

# Connection pool tuning (Node pg Pool) — use in production to avoid exhausting DB connections
PG_POOL_MAX=20
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=10000
# Optional smaller cap for the pgvector pool (defaults to min(PG_POOL_MAX, 10))
# PG_VECTOR_POOL_MAX=10

# Embeddings for articles_cache (pgvector): hf (default) or openai
EMBEDDING_PROVIDER=hf
# Hugging Face Inference: sentence-transformers/all-MiniLM-L6-v2 (or compatible)
HUGGINGFACE_TOKEN=
# Optional: OpenAI text-embedding-3-small with dimensions=384 (set OPENAI_KEY or existing key var used by server)
OPENAI_KEY=
OPENAI_API_KEY=

# Session Secret (generate a strong random string)
SESSION_SECRET=your_session_secret_here

# JWT Secret (REQUIRED for production — must be a strong, unique 256+ bit key)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_change_in_production

# Admin Token for protected endpoints (generate a strong random string)
ADMIN_TOKEN=your_admin_token_here

# CORS Origins (comma-separated)
# In production, this MUST be set to your actual domain(s).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional Redis URL (enables shared rate-limit store across instances)
REDIS_URL=

# Structured logging level: debug | info | warn | error
LOG_LEVEL=info

# Strict production readiness guards (fail-fast on misconfiguration)
REQUIRE_SMTP=false
REQUIRE_VECTOR_SEARCH=false

# BioGPT Server URL (also sets /health localAI when set)
BIOGPT_SERVER_URL=http://localhost:8000
# Or force local AI feature flag in health
ENABLE_LOCAL_AI=false

# =============================================================================
# EMAIL (SMTP) — Required for weekly digest emails
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Medical Research Digest <digest@yourdomain.com>
APP_URL=https://your-app-domain.com

# Optional OAuth login
API_URL=http://localhost:3002
CLIENT_URL=http://localhost:5173
OAUTH_SUCCESS_REDIRECT=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=

# =============================================================================
# FEATURE FLAGS
# =============================================================================

VITE_ENABLE_ANALYSIS=true
VITE_ENABLE_COLLABORATION=true
VITE_ENABLE_RECOMMENDATIONS=true
VITE_ENABLE_CITATION_NETWORK=true

# In-memory collaboration API (collections, invites, etc.). Set to true only if you need those routes.
ENABLE_COLLABORATION_API=false

# =============================================================================
# STRIPE (payments) — Required to accept subscriptions
# =============================================================================
# Get your keys at: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development, live keys (sk_live_...) for production.
STRIPE_SECRET_KEY=sk_test_...
# Create a Product + Price in Stripe Dashboard → Products, copy the Price ID (price_...)
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...
# Webhook secret — get from: stripe listen --forward-to localhost:3002/api/billing/webhook
# In production: Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Lightweight paywall gate for premium endpoints
# Applies to guideline alignment, patient case mode, and review CSV export.
# Set to true in production once Stripe is configured.
PAYWALL_ENABLED=false
# If true, bypass paywall outside production.
PAYWALL_ALLOW_IN_DEV=true
# Comma-separated roles that can use premium endpoints when paywall is enabled.
PAYWALL_ALLOWED_ROLES=admin,researcher,pro,enterprise

# =============================================================================
# BUILD CONFIGURATION
# =============================================================================

# App Version (auto-generated during build)
VITE_APP_VERSION=2.0.0

# Git commit SHA (auto-generated)
VITE_GIT_SHA=unknown
