# Signal MD production environment checklist
# Canonical launch gate: COMMERCIAL_READINESS.md -> Production Environment.
# Copy this file to your staging/production secret store and replace every value.
# Verify with:
#   NODE_ENV=production npm run verify:production-env
#   NODE_ENV=production npm run beta:safety

# Runtime
NODE_ENV=production
APP_ROLE=web
PORT=3002
APP_URL=https://signalmd.co
CLIENT_URL=https://signalmd.co
API_URL=https://signalmd.co
CORS_ORIGINS=https://signalmd.co
DEV_DISABLE_AUTH=false

# PostgreSQL app data and pgvector
DATABASE_URL=postgresql://medsearch:replace-me@postgres:5432/medsearch
USE_POSTGRES_MAIN=true
PG_VECTOR_URL=postgresql://medsearch:replace-me@postgres:5432/medsearch
VECTOR_DATABASE_URL=
PGSSL=false
PG_POOL_MAX=20
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=10000

# Redis shared cache, rate limits, auth store, BullMQ
REDIS_URL=redis://:replace-me@redis:6379
DISABLE_BULLMQ=false

# Auth secrets
JWT_SECRET=replace-with-64-byte-hex-at-least-32-chars
SESSION_SECRET=replace-with-64-byte-hex
ADMIN_TOKEN=replace-with-64-byte-hex

# Billing gate
PAYWALL_ENABLED=true
PAYWALL_ALLOW_IN_DEV=false
REQUIRE_STRIPE=true
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_RESEARCHER_PRICE_ID=price_replace_me
STRIPE_PRO_PRICE_ID=price_replace_me
STRIPE_TEAM_PRICE_ID=price_replace_me

# Email verification, password reset, digests
REQUIRE_SMTP=true
RESEND_API_KEY=re_replace_me
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Signal MD <hello@signalmd.co>
EMAIL_SUPPRESSION_LIST=

# Error tracking and tracing
SENTRY_DSN=https://replace-me@o000000.ingest.sentry.io/000000
SENTRY_RELEASE=2.0.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_AI_TRACES_SAMPLE_RATE=0.2
OTEL_ENABLED=false
OTEL_SERVICE_NAME=signal-md
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# At least one LLM provider is required
GEMINI_API_KEY=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=

# Search, embeddings, and PDFs
NCBI_API_KEY=
NCBI_EMAIL=ops@signalmd.co
SEMANTIC_SCHOLAR_KEY=
HUGGINGFACE_TOKEN=
EMBEDDING_PROVIDER=hf
OPENAI_API_KEY=
GROBID_URL=http://grobid:8070
REQUIRE_VECTOR_SEARCH=true

# Production behavior flags
AUTO_SEED_ON_SEARCH=false
AGENT_LLM_INTENT_CLASSIFIER=false
AGENT_TURN_MEMORY_ENABLED=true
BETA_MODE=false
LOG_LEVEL=info

# Worker deployment companion values
# Use APP_ROLE=worker and WORKER_HEALTH_PORT=3003 in the worker process.
WORKER_HEALTH_PORT=3003
