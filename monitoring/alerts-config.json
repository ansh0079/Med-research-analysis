{
  "sentry": {
    "enabled": true,
    "alerts": [
      {
        "name": "High Error Rate",
        "metric": "error_rate",
        "threshold": 5,
        "window": "5m",
        "severity": "warning",
        "notification": ["email"]
      },
      {
        "name": "Critical Error Rate",
        "metric": "error_rate",
        "threshold": 20,
        "window": "5m",
        "severity": "critical",
        "notification": ["email"]
      },
      {
        "name": "New Issues Spike",
        "metric": "new_issues",
        "threshold": 10,
        "window": "1h",
        "severity": "warning",
        "notification": ["email"]
      },
      {
        "name": "Search Latency Regression",
        "metric": "transaction.duration",
        "threshold": 3000,
        "window": "15m",
        "severity": "warning",
        "filter": "transaction:/api/search",
        "notification": ["email"]
      }
    ]
  },
  "uptime": {
    "enabled": true,
    "alerts": [
      {
        "name": "Downtime",
        "condition": "down",
        "threshold": 0,
        "notification": ["email"]
      },
      {
        "name": "Slow Response",
        "metric": "response_time",
        "threshold": 5000,
        "window": "3 checks",
        "severity": "warning",
        "notification": ["email"]
      }
    ]
  },
  "notification_channels": {
    "email": {
      "enabled": true,
      "recipients": ["ansh0079@gmail.com"]
    }
  }
}
