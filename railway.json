{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run setup",
    "nixpacksPlan": {
      "providers": [
        "node"
      ],
      "buildImage": "ghcr.io/railwayapp/nixpacks:ubuntu-1707761357"
    }
  },
  "deploy": {
    "startCommand": "node server.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "environments": {
    "production": {
      "variables": {
        "NODE_ENV": "production",
        "PORT": "${{PORT}}",
        "HUGGINGFACE_TOKEN": "${{HF_API_KEY}}",
        "ADMIN_TOKEN": "${{ADMIN_KEY}}"
      }
    }
  }
}